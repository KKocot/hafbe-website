---
import "../styles/global.css";
import Navbar from "../components/Navbar.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "HAF Block Explorer — Blockchain API for Hive",
  description = "Query transactions, accounts, witnesses and blocks through a clean REST API built on PostgreSQL and HAF.",
} = Astro.props;
---

<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/og-image.png" />
    <meta property="og:url" content="https://hafbe.hive.blog/" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="HAF Block Explorer — Blockchain API for Hive" />
    <meta name="twitter:description" content="Query transactions, accounts, witnesses and blocks through a clean REST API." />
    <link rel="canonical" href={Astro.url.href} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <noscript><style>[data-animate]{opacity:1!important;transform:none!important}</style></noscript>
    <title>{title}</title>
  </head>
  <body class="bg-bg-primary text-text-primary font-sans antialiased">

    <Navbar />

    <!-- Spacer for fixed header -->
    <div class="h-16"></div>

    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-border-subtle">
      <div class="mx-auto max-w-[75rem] px-6 py-12 flex flex-col sm:flex-row items-center justify-between gap-4">
        <p class="text-sm text-text-tertiary">&copy; {new Date().getFullYear()} HAF Block Explorer &middot; MIT License</p>
        <div class="flex items-center gap-6">
          <a
            href="https://gitlab.syncad.com/hive/haf_block_explorer"
            target="_blank"
            rel="noopener noreferrer"
            class="text-sm text-text-tertiary hover:text-text-secondary transition-colors"
          >GitLab</a>
          <a
            href="https://api.hive.blog/hafbe-api/"
            target="_blank"
            rel="noopener noreferrer"
            class="text-sm text-text-tertiary hover:text-text-secondary transition-colors"
          >API</a>
          <a
            href="https://explore.openhive.network/"
            target="_blank"
            rel="noopener noreferrer"
            class="text-sm text-text-tertiary hover:text-text-secondary transition-colors"
          >Explorer</a>
        </div>
      </div>
    </footer>

  </body>
</html>
