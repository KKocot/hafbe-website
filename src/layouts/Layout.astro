---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "HAF Block Explorer — Blockchain API for Hive",
  description = "Query transactions, accounts, witnesses and blocks through a clean REST API built on PostgreSQL and HAF.",
} = Astro.props;
---

<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/og-image.png" />
    <meta property="og:url" content="https://hafbe.hive.blog/" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="HAF Block Explorer — Blockchain API for Hive" />
    <meta name="twitter:description" content="Query transactions, accounts, witnesses and blocks through a clean REST API." />
    <link rel="canonical" href={Astro.url.href} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <noscript><style>[data-animate]{opacity:1!important;transform:none!important}</style></noscript>
    <title>{title}</title>
  </head>
  <body class="bg-bg-primary text-text-primary font-sans antialiased">

    <!-- Header -->
    <header class="fixed top-0 left-0 right-0 z-50 bg-bg-primary/80 backdrop-blur-md border-b border-border-subtle">
      <nav class="mx-auto max-w-[75rem] flex items-center justify-between px-6 h-16">
        <a href="/" class="text-lg font-bold tracking-tight text-text-primary">HAFBE</a>

        <!-- Desktop nav -->
        <div class="hidden md:flex items-center gap-8">
          <a href="#features" class="text-sm text-text-secondary hover:text-text-primary transition-colors">Features</a>
          <a href="#api-preview" class="text-sm text-text-secondary hover:text-text-primary transition-colors">API</a>
          <a href="#tech-stack" class="text-sm text-text-secondary hover:text-text-primary transition-colors">Tech Stack</a>
          <a
            href="https://api.hive.blog/hafbe-api/"
            target="_blank"
            rel="noopener noreferrer"
            class="text-sm font-medium text-bg-primary bg-accent hover:bg-accent/90 px-4 py-2 rounded-lg transition-colors"
          >API Docs</a>
        </div>

        <!-- Mobile hamburger (CSS-only) -->
        <label for="mobile-menu-toggle" class="md:hidden cursor-pointer p-2 -mr-2" aria-label="Toggle menu">
          <svg class="w-6 h-6 text-text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </label>
      </nav>

      <!-- Mobile menu (CSS-only checkbox hack) -->
      <input type="checkbox" id="mobile-menu-toggle" class="peer sr-only" aria-label="Mobile navigation menu" />
      <div class="md:hidden max-h-0 overflow-hidden peer-checked:max-h-64 transition-[max-height] duration-300 ease-in-out bg-bg-primary border-b border-border-subtle">
        <div class="mobile-nav flex flex-col gap-4 px-6 py-6">
          <a href="#features" class="text-sm text-text-secondary hover:text-text-primary transition-colors">Features</a>
          <a href="#api-preview" class="text-sm text-text-secondary hover:text-text-primary transition-colors">API</a>
          <a href="#tech-stack" class="text-sm text-text-secondary hover:text-text-primary transition-colors">Tech Stack</a>
          <a
            href="https://api.hive.blog/hafbe-api/"
            target="_blank"
            rel="noopener noreferrer"
            class="text-sm font-medium text-bg-primary bg-accent hover:bg-accent/90 px-4 py-2 rounded-lg transition-colors text-center"
          >API Docs</a>
        </div>
      </div>
      <script>
        document.querySelectorAll('.mobile-nav a').forEach(link => {
          link.addEventListener('click', () => {
            document.getElementById('mobile-menu-toggle').checked = false;
          });
        });
      </script>
    </header>

    <!-- Spacer for fixed header -->
    <div class="h-16"></div>

    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-border-subtle">
      <div class="mx-auto max-w-[75rem] px-6 py-12 flex flex-col sm:flex-row items-center justify-between gap-4">
        <p class="text-sm text-text-tertiary">&copy; {new Date().getFullYear()} HAF Block Explorer &middot; MIT License</p>
        <div class="flex items-center gap-6">
          <a
            href="https://gitlab.syncad.com/hive/haf_block_explorer"
            target="_blank"
            rel="noopener noreferrer"
            class="text-sm text-text-tertiary hover:text-text-secondary transition-colors"
          >GitLab</a>
          <a
            href="https://api.hive.blog/hafbe-api/"
            target="_blank"
            rel="noopener noreferrer"
            class="text-sm text-text-tertiary hover:text-text-secondary transition-colors"
          >API</a>
          <a
            href="https://explore.openhive.network/"
            target="_blank"
            rel="noopener noreferrer"
            class="text-sm text-text-tertiary hover:text-text-secondary transition-colors"
          >Explorer</a>
        </div>
      </div>
    </footer>

  </body>
</html>
