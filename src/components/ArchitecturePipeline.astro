<section id="architecture" class="py-12 section-fullscreen border-t border-border-subtle" aria-labelledby="architecture-heading">
  <div class="mx-auto max-w-[75rem] px-6">

    <!-- Heading -->
    <div class="text-center max-w-2xl mx-auto" data-animate>
      <h2 id="architecture-heading" class="text-3xl sm:text-4xl font-bold tracking-[-0.02em] leading-[1.15]">How it works</h2>
      <p class="mt-4 text-text-secondary leading-relaxed">From blockchain to your application in milliseconds</p>
    </div>

    <!-- Pipeline -->
    <ol class="mt-16 flex flex-col lg:flex-row items-center justify-center gap-0">

      <!-- Step 1: Hive Network -->
      <li class="flex flex-col items-center text-center" data-animate style="--stagger: 0">
        <div class="w-16 h-16 rounded-full border border-border-subtle bg-bg-surface flex items-center justify-center">
          <svg class="w-7 h-7 text-text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418" />
          </svg>
        </div>
        <p class="mt-3 text-sm font-semibold text-text-primary">Hive Network</p>
        <p class="mt-1 text-xs text-text-tertiary">Block production</p>
      </li>

      <!-- Connector 1 -->
      <li class="hidden lg:flex items-center" aria-hidden="true">
        <div class="w-12 h-px bg-border-subtle"></div>
        <span class="text-accent text-sm font-medium -mx-1">&rarr;</span>
        <div class="w-12 h-px bg-border-subtle"></div>
      </li>
      <li class="lg:hidden flex justify-center" aria-hidden="true">
        <div class="h-8 w-px bg-border-subtle"></div>
      </li>

      <!-- Step 2: HAF Sync -->
      <li class="flex flex-col items-center text-center" data-animate style="--stagger: 1">
        <div class="w-16 h-16 rounded-full border border-border-subtle bg-bg-surface flex items-center justify-center">
          <svg class="w-7 h-7 text-text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
          </svg>
        </div>
        <p class="mt-3 text-sm font-semibold text-text-primary">HAF Sync</p>
        <p class="mt-1 text-xs text-text-tertiary">10K blocks/batch</p>
      </li>

      <!-- Connector 2 -->
      <li class="hidden lg:flex items-center" aria-hidden="true">
        <div class="w-12 h-px bg-border-subtle"></div>
        <span class="text-accent text-sm font-medium -mx-1">&rarr;</span>
        <div class="w-12 h-px bg-border-subtle"></div>
      </li>
      <li class="lg:hidden flex justify-center" aria-hidden="true">
        <div class="h-8 w-px bg-border-subtle"></div>
      </li>

      <!-- Step 3: PostgreSQL -->
      <li class="flex flex-col items-center text-center" data-animate style="--stagger: 2">
        <div class="w-16 h-16 rounded-full border border-border-subtle bg-bg-surface flex items-center justify-center">
          <svg class="w-7 h-7 text-text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 6.375c0 2.278-3.694 4.125-8.25 4.125S3.75 8.653 3.75 6.375m16.5 0c0-2.278-3.694-4.125-8.25-4.125S3.75 4.097 3.75 6.375m16.5 0v11.25c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125V6.375m16.5 0v3.75m-16.5-3.75v3.75m16.5 0v3.75C20.25 16.153 16.556 18 12 18s-8.25-1.847-8.25-4.125v-3.75m16.5 0c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125" />
          </svg>
        </div>
        <p class="mt-3 text-sm font-semibold text-text-primary">PostgreSQL</p>
        <p class="mt-1 text-xs text-text-tertiary">Indexed & queryable</p>
      </li>

      <!-- Connector 3 -->
      <li class="hidden lg:flex items-center" aria-hidden="true">
        <div class="w-12 h-px bg-border-subtle"></div>
        <span class="text-accent text-sm font-medium -mx-1">&rarr;</span>
        <div class="w-12 h-px bg-border-subtle"></div>
      </li>
      <li class="lg:hidden flex justify-center" aria-hidden="true">
        <div class="h-8 w-px bg-border-subtle"></div>
      </li>

      <!-- Step 4: PostgREST -->
      <li class="flex flex-col items-center text-center" data-animate style="--stagger: 3">
        <div class="w-16 h-16 rounded-full border border-border-subtle bg-bg-surface flex items-center justify-center">
          <svg class="w-7 h-7 text-text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5" />
          </svg>
        </div>
        <p class="mt-3 text-sm font-semibold text-text-primary">PostgREST</p>
        <p class="mt-1 text-xs text-text-tertiary">SQL &rarr; REST</p>
      </li>

      <!-- Connector 4 -->
      <li class="hidden lg:flex items-center" aria-hidden="true">
        <div class="w-12 h-px bg-border-subtle"></div>
        <span class="text-accent text-sm font-medium -mx-1">&rarr;</span>
        <div class="w-12 h-px bg-border-subtle"></div>
      </li>
      <li class="lg:hidden flex justify-center" aria-hidden="true">
        <div class="h-8 w-px bg-border-subtle"></div>
      </li>

      <!-- Step 5: Your App -->
      <li class="flex flex-col items-center text-center" data-animate style="--stagger: 4">
        <div class="w-16 h-16 rounded-full border border-border-subtle bg-bg-surface flex items-center justify-center">
          <svg class="w-7 h-7 text-text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.59 14.37a6 6 0 01-5.84 7.38v-4.8m5.84-2.58a14.98 14.98 0 006.16-12.12A14.98 14.98 0 009.631 8.41m5.96 5.96a14.926 14.926 0 01-5.841 2.58m-.119-8.54a6 6 0 00-7.381 5.84h4.8m2.581-5.84a14.927 14.927 0 00-2.58 5.84m2.699 2.7c-.103.021-.207.041-.311.06a15.09 15.09 0 01-2.448-2.448 14.9 14.9 0 01.06-.312m-2.24 2.39a4.493 4.493 0 00-1.757 4.306 4.493 4.493 0 004.306-1.758M16.5 9a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0z" />
          </svg>
        </div>
        <p class="mt-3 text-sm font-semibold text-text-primary">Your App</p>
        <p class="mt-1 text-xs text-text-tertiary">Simple HTTP GET</p>
      </li>

    </ol>

    <!-- Bottom note -->
    <p class="mt-12 text-center text-sm text-text-tertiary" data-animate style="--stagger: 5">
      Every PostgreSQL function becomes a REST endpoint automatically.
    </p>

  </div>
</section>
