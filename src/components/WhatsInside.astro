<section id="whats-inside" class="section-fullscreen py-12 border-t border-border-subtle" aria-labelledby="whats-inside-heading">
  <div class="mx-auto max-w-[75rem] px-6">

    <!-- Heading -->
    <div class="max-w-2xl" data-animate>
      <h2 id="whats-inside-heading" class="text-3xl sm:text-4xl font-bold tracking-[-0.02em] leading-[1.15]">What's Inside</h2>
      <p class="mt-4 text-text-secondary leading-relaxed">HAFBE is composed of specialized sub-applications, each handling a distinct aspect of blockchain data processing.</p>
    </div>

    <!-- Sub-application cards -->
    <div class="mt-14 grid grid-cols-1 lg:grid-cols-3 gap-4">

      <!-- Balance Tracker -->
      <div class="rounded-2xl border border-border-subtle bg-bg-surface p-7" data-animate style="--stagger: 1">
        <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg border border-border-subtle bg-bg-primary">
          <svg class="h-5 w-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M21 12V7H5a2 2 0 0 1 0-4h14v4" />
            <path d="M3 5v14a2 2 0 0 0 2 2h16v-5" />
            <path d="M18 12a2 2 0 0 0 0 4h4v-4z" />
          </svg>
        </div>
        <h3 class="text-base font-semibold text-text-primary">Balance Tracker</h3>
        <p class="mt-2 text-sm text-text-secondary leading-relaxed">Real-time account balance tracking across all Hive token types.</p>
        <ul class="mt-4 space-y-2">
          <li class="flex items-start gap-2 text-sm text-text-secondary leading-relaxed">
            <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-accent/60" aria-hidden="true"></span>
            HIVE, HBD, VESTS balances
          </li>
          <li class="flex items-start gap-2 text-sm text-text-secondary leading-relaxed">
            <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-accent/60" aria-hidden="true"></span>
            Savings & delegations
          </li>
          <li class="flex items-start gap-2 text-sm text-text-secondary leading-relaxed">
            <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-accent/60" aria-hidden="true"></span>
            Historical balance changes
          </li>
        </ul>
      </div>

      <!-- Reputation Tracker -->
      <div class="rounded-2xl border border-border-subtle bg-bg-surface p-7" data-animate style="--stagger: 2">
        <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg border border-border-subtle bg-bg-primary">
          <svg class="h-5 w-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12 2L9 9H2l6 4.5L5.5 21 12 16.5 18.5 21 16 13.5 22 9h-7z" />
          </svg>
        </div>
        <h3 class="text-base font-semibold text-text-primary">Reputation Tracker</h3>
        <p class="mt-2 text-sm text-text-secondary leading-relaxed">Account reputation score monitoring and history.</p>
        <ul class="mt-4 space-y-2">
          <li class="flex items-start gap-2 text-sm text-text-secondary leading-relaxed">
            <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-accent/60" aria-hidden="true"></span>
            Reputation score history
          </li>
          <li class="flex items-start gap-2 text-sm text-text-secondary leading-relaxed">
            <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-accent/60" aria-hidden="true"></span>
            Account authority tracking
          </li>
          <li class="flex items-start gap-2 text-sm text-text-secondary leading-relaxed">
            <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-accent/60" aria-hidden="true"></span>
            Key change monitoring
          </li>
        </ul>
      </div>

      <!-- HAfAH -->
      <div class="rounded-2xl border border-border-subtle bg-bg-surface p-7" data-animate style="--stagger: 3">
        <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg border border-border-subtle bg-bg-primary">
          <svg class="h-5 w-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M4 7V4h16v3" />
            <path d="M9 20h6" />
            <path d="M12 4v16" />
            <path d="M4 11h16" />
            <path d="M4 15h16" />
          </svg>
        </div>
        <h3 class="text-base font-semibold text-text-primary">
          HAfAH
          <span class="ml-1.5 text-xs font-normal text-text-tertiary">Account History API</span>
        </h3>
        <p class="mt-2 text-sm text-text-secondary leading-relaxed">Full account operation history without blockchain replay.</p>
        <ul class="mt-4 space-y-2">
          <li class="flex items-start gap-2 text-sm text-text-secondary leading-relaxed">
            <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-accent/60" aria-hidden="true"></span>
            No replay required — reads directly from HAF
          </li>
          <li class="flex items-start gap-2 text-sm text-text-secondary leading-relaxed">
            <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-accent/60" aria-hidden="true"></span>
            JSON-RPC 2.0 + REST
          </li>
          <li class="flex items-start gap-2 text-sm text-text-secondary leading-relaxed">
            <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-accent/60" aria-hidden="true"></span>
            Complete operation filtering
          </li>
        </ul>
      </div>

    </div>

    <!-- Feature pills -->
    <div class="mt-10 flex flex-wrap gap-3" data-animate style="--stagger: 4">
      {[
        { label: "SQL-first architecture", icon: "M20.25 6.375c0 2.278-3.694 4.125-8.25 4.125S3.75 8.653 3.75 6.375m16.5 0c0-2.278-3.694-4.125-8.25-4.125S3.75 4.097 3.75 6.375m16.5 0v11.25c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125V6.375" },
        { label: "Smart Caching — < 100ms responses", icon: "M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" },
        { label: "Fork Resistant", icon: "M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" },
        { label: "OpenAPI 3.1", icon: "M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z M14 2v6h6 M16 13H8 M16 17H8 M10 9H8" },
      ].map((pill) => (
        <span class="inline-flex items-center gap-2 rounded-full border border-border-subtle bg-bg-surface px-4 py-2 text-sm text-text-secondary">
          <svg class="h-3.5 w-3.5 text-accent shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d={pill.icon} />
          </svg>
          {pill.label}
        </span>
      ))}
    </div>

  </div>
</section>
