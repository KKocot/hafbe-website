---
const navLinks = [
  { href: '#features', section: 'features', label: 'Features' },
  { href: '#api-preview', section: 'api-preview', label: 'API' },
  { href: '#whats-inside', section: 'whats-inside', label: 'Tech Stack' },
];

const sectionIds = ['hero', ...navLinks.map(l => l.section)];
---

<header class="fixed top-0 left-0 right-0 z-50 bg-bg-primary/80 backdrop-blur-md border-b border-border-subtle">
  <nav class="mx-auto max-w-[75rem] flex items-center justify-between px-6 h-16" aria-label="Main navigation" data-sections={JSON.stringify(sectionIds)}>
    <a href="/" class="text-lg font-bold tracking-tight text-text-primary">HAFBE</a>

    <!-- Desktop nav -->
    <div class="hidden md:flex items-center gap-8">
      {navLinks.map(link => (
        <a href={link.href} data-section={link.section} class="nav-link text-sm text-text-secondary hover:text-text-primary transition-colors">{link.label}</a>
      ))}
      <a
        href="https://gitlab.syncad.com/hive/haf_block_explorer"
        target="_blank"
        rel="noopener noreferrer"
        class="text-text-secondary hover:text-text-primary transition-colors"
        aria-label="GitLab repository"
      >
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M22.65 14.39L12 22.13 1.35 14.39a.84.84 0 0 1-.3-.94l1.22-3.78 2.44-7.51a.42.42 0 0 1 .82 0l2.44 7.51h8.06l2.44-7.51a.42.42 0 0 1 .82 0l2.44 7.51 1.22 3.78a.84.84 0 0 1-.3.94z"/>
        </svg>
      </a>
    </div>

    <!-- Mobile hamburger (CSS-only) -->
    <label for="mobile-menu-toggle" class="md:hidden cursor-pointer p-2 -mr-2" aria-label="Toggle menu">
      <svg class="w-6 h-6 text-text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </label>
  </nav>

  <!-- Mobile menu (CSS-only checkbox hack) -->
  <input type="checkbox" id="mobile-menu-toggle" class="peer sr-only" aria-label="Mobile navigation menu" aria-controls="mobile-nav-panel" />
  <div id="mobile-nav-panel" class="md:hidden max-h-0 overflow-hidden peer-checked:max-h-64 transition-[max-height] duration-300 ease-in-out bg-bg-primary border-b border-border-subtle">
    <div class="mobile-nav flex flex-col gap-4 px-6 py-6">
      {navLinks.map(link => (
        <a href={link.href} data-section={link.section} class="nav-link text-sm text-text-secondary hover:text-text-primary transition-colors">{link.label}</a>
      ))}
      <a
        href="https://gitlab.syncad.com/hive/haf_block_explorer"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-2 text-sm text-text-secondary hover:text-text-primary transition-colors"
        aria-label="GitLab repository"
      >
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M22.65 14.39L12 22.13 1.35 14.39a.84.84 0 0 1-.3-.94l1.22-3.78 2.44-7.51a.42.42 0 0 1 .82 0l2.44 7.51h8.06l2.44-7.51a.42.42 0 0 1 .82 0l2.44 7.51 1.22 3.78a.84.84 0 0 1-.3.94z"/>
        </svg>
        GitLab
      </a>
    </div>
  </div>
  <script>
    const nav = document.querySelector('nav[data-sections]')!;
    const sectionIds: string[] = JSON.parse(nav.dataset.sections!);
    const ACTIVE_CLASS = 'nav-active';
    const navLinks = document.querySelectorAll<HTMLAnchorElement>('a.nav-link[data-section]');

    // Close mobile menu on link click
    document.querySelectorAll('.mobile-nav a').forEach(link => {
      link.addEventListener('click', () => {
        const toggle = document.getElementById('mobile-menu-toggle') as HTMLInputElement | null;
        if (toggle) toggle.checked = false;
      });
    });

    // Scroll spy
    let currentActive: string | null = null;

    function setActive(sectionId: string | null) {
      if (sectionId === currentActive) return;
      currentActive = sectionId;
      navLinks.forEach(link => {
        link.classList.toggle(ACTIVE_CLASS, link.dataset.section === sectionId);
      });
    }

    const visibleSections = new Map<string, IntersectionObserverEntry>();

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            visibleSections.set(entry.target.id, entry);
          } else {
            visibleSections.delete(entry.target.id);
          }
        }

        if (visibleSections.size === 0) { setActive(null); return; }

        let topSection: string | null = null;
        for (const id of sectionIds) {
          if (visibleSections.has(id)) { topSection = id; break; }
        }

        setActive(topSection === 'hero' ? null : topSection);
      },
      { rootMargin: '-64px 0px -35% 0px', threshold: 0 }
    );

    for (const id of sectionIds) {
      const el = document.getElementById(id);
      if (el) observer.observe(el);
    }
  </script>
</header>
