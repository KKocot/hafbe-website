---
import { endpoints, groupOrder } from "../data/endpoints";

const grouped = groupOrder.map((group) => ({
  name: group,
  items: endpoints.filter((e) => e.group === group),
}));

---

<section id="features" class="py-12 border-t border-border-subtle" aria-labelledby="features-heading">
  <div class="mx-auto max-w-[75rem] px-6">
    <div class="max-w-2xl" data-animate>
      <h2 id="features-heading" class="text-3xl sm:text-4xl font-bold tracking-[-0.02em] leading-[1.15]">API Reference</h2>
      <p class="mt-4 text-text-secondary leading-relaxed">Complete endpoint reference for the HAF Block Explorer API.</p>
    </div>

    <div class="mt-14 grid grid-cols-1 lg:grid-cols-2 gap-4">
      {grouped.map((group, groupIndex) => {
        const isUtility = group.name === "Utility";
        const countLabel = group.items.length === 1 ? "1 endpoint" : `${group.items.length} endpoints`;

        return (
          <div
            class:list={[
              "rounded-2xl border border-border-subtle bg-bg-surface p-7",
              isUtility && "lg:col-span-2",
            ]}
            data-animate
            style={`--stagger: ${groupIndex}`}
          >
            <div class="flex items-center justify-between mb-5">
              <h3 class="text-base font-semibold text-text-primary">{group.name}</h3>
              <span class="text-xs text-text-tertiary">{countLabel}</span>
            </div>
            <ul class:list={[isUtility ? "grid grid-cols-1 sm:grid-cols-2 gap-3" : "space-y-3"]}>
              {group.items.map((endpoint) => (
                <li class="flex flex-col gap-1">
                  <div class="flex items-center gap-2">
                    <span class="shrink-0 rounded px-1.5 py-0.5 text-[0.6875rem] font-semibold leading-none bg-accent/15 text-accent">
                      {endpoint.method}
                    </span>
                    <code class="text-sm font-mono text-text-primary truncate">{endpoint.path}</code>
                  </div>
                  <p class="text-sm text-text-secondary leading-relaxed pl-10">{endpoint.description}</p>
                </li>
              ))}
            </ul>
          </div>
        );
      })}
    </div>
  </div>
</section>
