---
import Layout from "../layouts/Layout.astro";
import ApiPreview from "../components/ApiPreview.astro";
import ArchitecturePipeline from "../components/ArchitecturePipeline.astro";
---

<Layout>

  <!-- Hero -->
  <section class="section-fullscreen relative overflow-hidden py-12" data-animate aria-labelledby="hero-heading">
    <!-- Animated background -->
    <div class="hero-bg absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
      <div class="hero-grid absolute inset-0"></div>
      <div class="hero-glow absolute inset-0"></div>
    </div>

    <div class="relative z-10 mx-auto max-w-[75rem] px-6">
      <div class="max-w-3xl">
        <h1 id="hero-heading" class="text-4xl sm:text-5xl md:text-6xl lg:text-[4rem] font-bold tracking-[-0.02em] leading-[1.1] text-text-primary">
          Blockchain API<br />for Hive
        </h1>
        <p class="mt-6 text-lg text-text-secondary max-w-xl leading-relaxed">
          Query transactions, accounts, witnesses and blocks through a clean REST API. No node required.
        </p>
      </div>

      <!-- Metrics -->
      <div class="mt-12 grid grid-cols-1 sm:grid-cols-3 gap-4 max-w-2xl">
        <div class="rounded-xl border border-border-subtle bg-bg-surface px-6 py-5" data-animate style="--stagger: 1">
          <p class="text-2xl font-bold text-accent">18</p>
          <p class="mt-1 text-sm text-text-secondary">Endpoints</p>
        </div>
        <div class="rounded-xl border border-border-subtle bg-bg-surface px-6 py-5" data-animate style="--stagger: 2">
          <p class="text-2xl font-bold text-accent">3</p>
          <p class="mt-1 text-sm text-text-secondary">Modules</p>
        </div>
        <div class="rounded-xl border border-border-subtle bg-bg-surface px-6 py-5" data-animate style="--stagger: 3">
          <svg class="w-5 h-5 text-accent mb-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
          </svg>
          <p class="text-sm text-text-secondary">Real-time Sync</p>
        </div>
      </div>

      <!-- Buttons -->
      <div class="mt-10 flex flex-wrap gap-4">
        <a
          href="https://api.hive.blog/hafbe-api/"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-lg bg-accent px-6 py-3 text-sm font-medium text-bg-primary hover:bg-accent/90 transition-colors"
        >Explore API</a>
        <a
          href="https://gitlab.syncad.com/hive/haf_block_explorer"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-lg border border-border-subtle px-6 py-3 text-sm font-medium text-text-primary hover:border-text-tertiary transition-colors"
        >View on GitLab</a>
      </div>

      <!-- Block counter -->
      <div class="mt-10 inline-flex items-center gap-2 rounded-lg border border-border-subtle bg-bg-surface px-4 py-2.5">
        <span class="relative flex h-2.5 w-2.5">
          <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-accent opacity-75"></span>
          <span class="relative inline-flex h-2.5 w-2.5 rounded-full bg-accent"></span>
        </span>
        <span class="text-sm text-text-secondary">Latest Block:</span>
        <span id="block-counter" class="text-sm font-mono font-medium text-text-primary">#91,000,000</span>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section id="features" class="section-fullscreen py-12 border-t border-border-subtle" aria-labelledby="features-heading">
    <div class="mx-auto max-w-[75rem] px-6">
      <div class="max-w-2xl" data-animate>
        <h2 id="features-heading" class="text-3xl sm:text-4xl font-bold tracking-[-0.02em] leading-[1.15]">Everything you need to explore Hive</h2>
        <p class="mt-4 text-text-secondary leading-relaxed">A complete toolkit for querying and analyzing Hive blockchain data.</p>
      </div>

      <div class="mt-14 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <!-- Block Search -->
        <div class="group rounded-2xl border border-border-subtle bg-bg-surface p-7 hover:border-accent/40 transition-colors" data-animate style="--stagger: 0">
          <div class="flex items-center justify-between mb-4">
            <svg class="w-5 h-5 text-text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
            </svg>
            <span class="inline-flex items-center gap-1.5 text-xs text-text-tertiary">
              <span class="h-1.5 w-1.5 rounded-full bg-accent"></span>Active
            </span>
          </div>
          <h3 class="text-base font-semibold text-text-primary">Block Search</h3>
          <p class="mt-2 text-sm text-text-secondary leading-relaxed">Search blocks by operation type, account, or time range.</p>
        </div>

        <!-- Account Details -->
        <div class="group rounded-2xl border border-border-subtle bg-bg-surface p-7 hover:border-accent/40 transition-colors" data-animate style="--stagger: 1">
          <div class="flex items-center justify-between mb-4">
            <svg class="w-5 h-5 text-text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
            </svg>
            <span class="inline-flex items-center gap-1.5 text-xs text-text-tertiary">
              <span class="h-1.5 w-1.5 rounded-full bg-accent"></span>Active
            </span>
          </div>
          <h3 class="text-base font-semibold text-text-primary">Account Details</h3>
          <p class="mt-2 text-sm text-text-secondary leading-relaxed">Full account info with balances, authority keys, and post history.</p>
        </div>

        <!-- Witness Ranking -->
        <div class="group rounded-2xl border border-border-subtle bg-bg-surface p-7 hover:border-accent/40 transition-colors" data-animate style="--stagger: 2">
          <div class="flex items-center justify-between mb-4">
            <svg class="w-5 h-5 text-text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
            </svg>
            <span class="inline-flex items-center gap-1.5 text-xs text-text-tertiary">
              <span class="h-1.5 w-1.5 rounded-full bg-accent"></span>Active
            </span>
          </div>
          <h3 class="text-base font-semibold text-text-primary">Witness Ranking</h3>
          <p class="mt-2 text-sm text-text-secondary leading-relaxed">Complete witness data: rank, votes, price feeds, missed blocks.</p>
        </div>

        <!-- Transaction Stats -->
        <div class="group rounded-2xl border border-border-subtle bg-bg-surface p-7 hover:border-accent/40 transition-colors" data-animate style="--stagger: 3">
          <div class="flex items-center justify-between mb-4">
            <svg class="w-5 h-5 text-text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18L9 11.25l4.306 4.307a11.95 11.95 0 015.814-5.519l2.74-1.22m0 0l-5.94-2.28m5.94 2.28l-2.28 5.941" />
            </svg>
            <span class="inline-flex items-center gap-1.5 text-xs text-text-tertiary">
              <span class="h-1.5 w-1.5 rounded-full bg-accent"></span>Active
            </span>
          </div>
          <h3 class="text-base font-semibold text-text-primary">Transaction Stats</h3>
          <p class="mt-2 text-sm text-text-secondary leading-relaxed">Daily, monthly, and yearly transaction aggregates.</p>
        </div>

        <!-- Balance Tracking -->
        <div class="group rounded-2xl border border-border-subtle bg-bg-surface p-7 hover:border-accent/40 transition-colors" data-animate style="--stagger: 4">
          <div class="flex items-center justify-between mb-4">
            <svg class="w-5 h-5 text-text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 12a2.25 2.25 0 00-2.25-2.25H15a3 3 0 11-6 0H5.25A2.25 2.25 0 003 12m18 0v6a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 18v-6m18 0V9M3 12V9m18 0a2.25 2.25 0 00-2.25-2.25H5.25A2.25 2.25 0 003 9m18 0V6a2.25 2.25 0 00-2.25-2.25H5.25A2.25 2.25 0 003 6v3" />
            </svg>
            <span class="inline-flex items-center gap-1.5 text-xs text-text-tertiary">
              <span class="h-1.5 w-1.5 rounded-full bg-accent"></span>Active
            </span>
          </div>
          <h3 class="text-base font-semibold text-text-primary">Balance Tracking</h3>
          <p class="mt-2 text-sm text-text-secondary leading-relaxed">Real-time HIVE, HBD, VESTS balances with delegation tracking.</p>
        </div>

        <!-- Reputation System -->
        <div class="group rounded-2xl border border-border-subtle bg-bg-surface p-7 hover:border-accent/40 transition-colors" data-animate style="--stagger: 5">
          <div class="flex items-center justify-between mb-4">
            <svg class="w-5 h-5 text-text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z" />
            </svg>
            <span class="inline-flex items-center gap-1.5 text-xs text-text-tertiary">
              <span class="h-1.5 w-1.5 rounded-full bg-accent"></span>Active
            </span>
          </div>
          <h3 class="text-base font-semibold text-text-primary">Reputation System</h3>
          <p class="mt-2 text-sm text-text-secondary leading-relaxed">On-chain reputation calculation matching hived algorithm.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- API Preview -->
  <ApiPreview />

  <!-- Tech Stack -->
  <section id="tech-stack" class="section-fullscreen py-12 border-t border-border-subtle" aria-labelledby="tech-stack-heading">
    <div class="mx-auto max-w-[75rem] px-6">
      <div class="max-w-2xl" data-animate>
        <h2 id="tech-stack-heading" class="text-3xl sm:text-4xl font-bold tracking-[-0.02em] leading-[1.15]">Built on proven technology</h2>
      </div>

      <div class="mt-10 flex flex-wrap gap-3" data-animate style="--stagger: 1">
        {["PostgreSQL 14", "PostgREST", "HAF", "Docker", "PL/pgSQL", "OpenAPI 3.1"].map((tech) => (
          <span class="rounded-full border border-border-subtle bg-bg-surface px-4 py-2 text-sm text-text-secondary">{tech}</span>
        ))}
      </div>

      <div class="mt-14 grid grid-cols-1 sm:grid-cols-3 gap-4">
        <div class="rounded-2xl border border-border-subtle bg-bg-surface p-7" data-animate style="--stagger: 2">
          <h3 class="text-base font-semibold text-text-primary">SQL-first</h3>
          <p class="mt-2 text-sm text-text-secondary leading-relaxed">Every PostgreSQL function becomes a REST endpoint automatically. Zero server boilerplate.</p>
        </div>
        <div class="rounded-2xl border border-border-subtle bg-bg-surface p-7" data-animate style="--stagger: 3">
          <h3 class="text-base font-semibold text-text-primary">Smart Caching</h3>
          <p class="mt-2 text-sm text-text-secondary leading-relaxed">Historical data cached for 1 year. Live data refreshed every 2 seconds.</p>
        </div>
        <div class="rounded-2xl border border-border-subtle bg-bg-surface p-7" data-animate style="--stagger: 4">
          <h3 class="text-base font-semibold text-text-primary">Fork Resistant</h3>
          <p class="mt-2 text-sm text-text-secondary leading-relaxed">HAF handles blockchain reorganizations. Your data is always consistent.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Architecture Pipeline -->
  <ArchitecturePipeline />

  <!-- CTA -->
  <section class="section-fullscreen py-12 border-t border-border-subtle relative overflow-hidden" aria-labelledby="cta-heading">
    <div class="absolute inset-0 bg-gradient-to-b from-accent/[0.03] to-transparent pointer-events-none"></div>
    <div class="mx-auto max-w-[75rem] px-6 relative">
      <div class="max-w-2xl" data-animate>
        <h2 id="cta-heading" class="text-3xl sm:text-4xl font-bold tracking-[-0.02em] leading-[1.15]">Start Building Today</h2>
        <p class="mt-4 text-text-secondary leading-relaxed">Access the full Hive blockchain through a clean REST API.</p>
      </div>

      <div class="mt-10 grid grid-cols-1 sm:grid-cols-3 gap-4 max-w-3xl">
        <a
          href="https://api.hive.blog/hafbe-api/"
          target="_blank"
          rel="noopener noreferrer"
          class="rounded-2xl border border-border-subtle bg-bg-surface p-7 hover:border-accent/40 transition-colors"
          data-animate style="--stagger: 1"
        >
          <h3 class="text-base font-semibold text-text-primary">API Documentation</h3>
          <p class="mt-2 text-sm text-text-secondary">OpenAPI spec &amp; endpoint reference</p>
        </a>
        <a
          href="https://api.hive.blog/hafbe-api/"
          target="_blank"
          rel="noopener noreferrer"
          class="rounded-2xl border border-border-subtle bg-bg-surface p-7 hover:border-accent/40 transition-colors"
          data-animate style="--stagger: 2"
        >
          <h3 class="text-base font-semibold text-text-primary">Swagger UI</h3>
          <p class="mt-2 text-sm text-text-secondary">Interactive API playground</p>
        </a>
        <a
          href="https://gitlab.syncad.com/hive/haf_block_explorer"
          target="_blank"
          rel="noopener noreferrer"
          class="rounded-2xl border border-border-subtle bg-bg-surface p-7 hover:border-accent/40 transition-colors"
          data-animate style="--stagger: 3"
        >
          <h3 class="text-base font-semibold text-text-primary">GitLab</h3>
          <p class="mt-2 text-sm text-text-secondary">Source code &amp; issues</p>
        </a>
      </div>
    </div>
  </section>

</Layout>

<script>
  // Block counter
  const counter = document.getElementById("block-counter");
  if (counter) {
    let block = 91000000;
    const fmt = new Intl.NumberFormat("en-US");
    const update = () => { counter.textContent = "#" + fmt.format(block); };
    update();
    setInterval(() => { block++; update(); }, 3000);
  }

  // Scroll animations
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((e) => { if (e.isIntersecting) { e.target.classList.add("visible"); observer.unobserve(e.target); } });
    },
    { threshold: 0.15 }
  );
  document.querySelectorAll("[data-animate]").forEach((el) => observer.observe(el));
</script>
