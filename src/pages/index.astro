---
import Layout from "../layouts/Layout.astro";
import ApiPreview from "../components/ApiPreview.astro";
import ArchitecturePipeline from "../components/ArchitecturePipeline.astro";
---

<Layout>

  <!-- Hero -->
  <section class="section-fullscreen relative overflow-hidden py-12" data-animate aria-labelledby="hero-heading">
    <!-- Animated background -->
    <div class="hero-bg absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
      <div class="hero-grid absolute inset-0"></div>
      <div class="hero-glow absolute inset-0"></div>
    </div>

    <div class="relative z-10 mx-auto max-w-[75rem] px-6">
      <div class="max-w-3xl">
        <h1 id="hero-heading" class="text-4xl sm:text-5xl md:text-6xl lg:text-[4rem] font-bold tracking-[-0.02em] leading-[1.1] text-text-primary">
          Blockchain API<br />for Hive
        </h1>
        <p class="mt-6 text-lg text-text-secondary max-w-xl leading-relaxed">
          Query transactions, accounts, witnesses and blocks through a clean REST API. No node required.
        </p>
      </div>

      <!-- Buttons -->
      <div class="mt-10 flex flex-wrap gap-4">
        <a
          href="https://explore.openhive.network/"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-lg bg-accent px-6 py-3 text-sm font-medium text-bg-primary hover:bg-accent/90 transition-colors"
        >Explore API</a>
        <a
          href="https://gitlab.syncad.com/hive/haf_block_explorer"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-lg border border-border-subtle px-6 py-3 text-sm font-medium text-text-primary hover:border-text-tertiary transition-colors"
        >View on GitLab</a>
      </div>

      <!-- Block counter -->
      <div class="mt-10 inline-flex items-center gap-2 rounded-lg border border-border-subtle bg-bg-surface px-4 py-2.5">
        <span class="relative flex h-2.5 w-2.5">
          <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-accent opacity-75"></span>
          <span class="relative inline-flex h-2.5 w-2.5 rounded-full bg-accent"></span>
        </span>
        <span class="text-sm text-text-secondary">Latest Block:</span>
        <span id="block-counter" class="text-sm font-mono font-medium text-text-primary">Loading...</span>
      </div>
    </div>
  </section>

  <!-- API Reference -->
  <section id="features" class="py-12 border-t border-border-subtle" aria-labelledby="features-heading">
    <div class="mx-auto max-w-[75rem] px-6">
      <div class="max-w-2xl" data-animate>
        <h2 id="features-heading" class="text-3xl sm:text-4xl font-bold tracking-[-0.02em] leading-[1.15]">API Reference</h2>
        <p class="mt-4 text-text-secondary leading-relaxed">Complete endpoint reference for the HAF Block Explorer API.</p>
      </div>

      <div class="mt-14 grid grid-cols-1 lg:grid-cols-2 gap-4">

        <!-- Witnesses -->
        <div class="rounded-2xl border border-border-subtle bg-bg-surface p-7" data-animate style="--stagger: 0">
          <div class="flex items-center justify-between mb-5">
            <h3 class="text-base font-semibold text-text-primary">Witnesses</h3>
            <span class="text-xs text-text-tertiary">5 endpoints</span>
          </div>
          <ul class="space-y-3">
            <li class="flex flex-col gap-1">
              <div class="flex items-center gap-2">
                <span class="shrink-0 rounded px-1.5 py-0.5 text-[0.6875rem] font-semibold leading-none bg-accent/15 text-accent">GET</span>
                <code class="text-sm font-mono text-text-primary truncate">/witnesses</code>
              </div>
              <p class="text-sm text-text-secondary leading-relaxed pl-10">Retrieve all witnesses with pagination and sorting</p>
            </li>
            <li class="flex flex-col gap-1">
              <div class="flex items-center gap-2">
                <span class="shrink-0 rounded px-1.5 py-0.5 text-[0.6875rem] font-semibold leading-none bg-accent/15 text-accent">GET</span>
                <code class="text-sm font-mono text-text-primary truncate">{'/witnesses/{account-name}'}</code>
              </div>
              <p class="text-sm text-text-secondary leading-relaxed pl-10">Detailed info for a specific witness</p>
            </li>
            <li class="flex flex-col gap-1">
              <div class="flex items-center gap-2">
                <span class="shrink-0 rounded px-1.5 py-0.5 text-[0.6875rem] font-semibold leading-none bg-accent/15 text-accent">GET</span>
                <code class="text-sm font-mono text-text-primary truncate">{'/witnesses/{account-name}/voters'}</code>
              </div>
              <p class="text-sm text-text-secondary leading-relaxed pl-10">Accounts voting for a witness</p>
            </li>
            <li class="flex flex-col gap-1">
              <div class="flex items-center gap-2">
                <span class="shrink-0 rounded px-1.5 py-0.5 text-[0.6875rem] font-semibold leading-none bg-accent/15 text-accent">GET</span>
                <code class="text-sm font-mono text-text-primary truncate">{'/witnesses/{account-name}/voters/count'}</code>
              </div>
              <p class="text-sm text-text-secondary leading-relaxed pl-10">Voter count for a witness</p>
            </li>
            <li class="flex flex-col gap-1">
              <div class="flex items-center gap-2">
                <span class="shrink-0 rounded px-1.5 py-0.5 text-[0.6875rem] font-semibold leading-none bg-accent/15 text-accent">GET</span>
                <code class="text-sm font-mono text-text-primary truncate">{'/witnesses/{account-name}/votes/history'}</code>
              </div>
              <p class="text-sm text-text-secondary leading-relaxed pl-10">Vote history for a witness</p>
            </li>
          </ul>
        </div>

        <!-- Accounts -->
        <div class="rounded-2xl border border-border-subtle bg-bg-surface p-7" data-animate style="--stagger: 1">
          <div class="flex items-center justify-between mb-5">
            <h3 class="text-base font-semibold text-text-primary">Accounts</h3>
            <span class="text-xs text-text-tertiary">5 endpoints</span>
          </div>
          <ul class="space-y-3">
            <li class="flex flex-col gap-1">
              <div class="flex items-center gap-2">
                <span class="shrink-0 rounded px-1.5 py-0.5 text-[0.6875rem] font-semibold leading-none bg-accent/15 text-accent">GET</span>
                <code class="text-sm font-mono text-text-primary truncate">{'/accounts/{account-name}'}</code>
              </div>
              <p class="text-sm text-text-secondary leading-relaxed pl-10">Account balances and parameters</p>
            </li>
            <li class="flex flex-col gap-1">
              <div class="flex items-center gap-2">
                <span class="shrink-0 rounded px-1.5 py-0.5 text-[0.6875rem] font-semibold leading-none bg-accent/15 text-accent">GET</span>
                <code class="text-sm font-mono text-text-primary truncate">{'/accounts/{account-name}/authority'}</code>
              </div>
              <p class="text-sm text-text-secondary leading-relaxed pl-10">Cryptographic key authorities</p>
            </li>
            <li class="flex flex-col gap-1">
              <div class="flex items-center gap-2">
                <span class="shrink-0 rounded px-1.5 py-0.5 text-[0.6875rem] font-semibold leading-none bg-accent/15 text-accent">GET</span>
                <code class="text-sm font-mono text-text-primary truncate">{'/accounts/{account-name}/proxy-power'}</code>
              </div>
              <p class="text-sm text-text-secondary leading-relaxed pl-10">Delegators and vested power</p>
            </li>
            <li class="flex flex-col gap-1">
              <div class="flex items-center gap-2">
                <span class="shrink-0 rounded px-1.5 py-0.5 text-[0.6875rem] font-semibold leading-none bg-accent/15 text-accent">GET</span>
                <code class="text-sm font-mono text-text-primary truncate">{'/accounts/{account-name}/comment-permlinks'}</code>
              </div>
              <p class="text-sm text-text-secondary leading-relaxed pl-10">Post/comment identifiers</p>
            </li>
            <li class="flex flex-col gap-1">
              <div class="flex items-center gap-2">
                <span class="shrink-0 rounded px-1.5 py-0.5 text-[0.6875rem] font-semibold leading-none bg-accent/15 text-accent">GET</span>
                <code class="text-sm font-mono text-text-primary truncate">{'/accounts/{account-name}/operations/comments/{permlink}'}</code>
              </div>
              <p class="text-sm text-text-secondary leading-relaxed pl-10">Operations for a post/comment</p>
            </li>
          </ul>
        </div>

        <!-- Block Search -->
        <div class="rounded-2xl border border-border-subtle bg-bg-surface p-7" data-animate style="--stagger: 2">
          <div class="flex items-center justify-between mb-5">
            <h3 class="text-base font-semibold text-text-primary">Block Search</h3>
            <span class="text-xs text-text-tertiary">1 endpoint</span>
          </div>
          <ul class="space-y-3">
            <li class="flex flex-col gap-1">
              <div class="flex items-center gap-2">
                <span class="shrink-0 rounded px-1.5 py-0.5 text-[0.6875rem] font-semibold leading-none bg-accent/15 text-accent">GET</span>
                <code class="text-sm font-mono text-text-primary truncate">/block-search</code>
              </div>
              <p class="text-sm text-text-secondary leading-relaxed pl-10">Find blocks by operation type, account, time range</p>
            </li>
          </ul>
        </div>

        <!-- Transactions -->
        <div class="rounded-2xl border border-border-subtle bg-bg-surface p-7" data-animate style="--stagger: 3">
          <div class="flex items-center justify-between mb-5">
            <h3 class="text-base font-semibold text-text-primary">Transactions</h3>
            <span class="text-xs text-text-tertiary">1 endpoint</span>
          </div>
          <ul class="space-y-3">
            <li class="flex flex-col gap-1">
              <div class="flex items-center gap-2">
                <span class="shrink-0 rounded px-1.5 py-0.5 text-[0.6875rem] font-semibold leading-none bg-accent/15 text-accent">GET</span>
                <code class="text-sm font-mono text-text-primary truncate">/transaction-statistics</code>
              </div>
              <p class="text-sm text-text-secondary leading-relaxed pl-10">Aggregated transaction counts by day/month/year</p>
            </li>
          </ul>
        </div>

        <!-- Utility -->
        <div class="rounded-2xl border border-border-subtle bg-bg-surface p-7 lg:col-span-2" data-animate style="--stagger: 4">
          <div class="flex items-center justify-between mb-5">
            <h3 class="text-base font-semibold text-text-primary">Utility</h3>
            <span class="text-xs text-text-tertiary">4 endpoints</span>
          </div>
          <ul class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            <li class="flex flex-col gap-1">
              <div class="flex items-center gap-2">
                <span class="shrink-0 rounded px-1.5 py-0.5 text-[0.6875rem] font-semibold leading-none bg-accent/15 text-accent">GET</span>
                <code class="text-sm font-mono text-text-primary truncate">/version</code>
              </div>
              <p class="text-sm text-text-secondary leading-relaxed pl-10">Application version</p>
            </li>
            <li class="flex flex-col gap-1">
              <div class="flex items-center gap-2">
                <span class="shrink-0 rounded px-1.5 py-0.5 text-[0.6875rem] font-semibold leading-none bg-accent/15 text-accent">GET</span>
                <code class="text-sm font-mono text-text-primary truncate">/last-synced-block</code>
              </div>
              <p class="text-sm text-text-secondary leading-relaxed pl-10">Most recent synced block number</p>
            </li>
            <li class="flex flex-col gap-1">
              <div class="flex items-center gap-2">
                <span class="shrink-0 rounded px-1.5 py-0.5 text-[0.6875rem] font-semibold leading-none bg-accent/15 text-accent">GET</span>
                <code class="text-sm font-mono text-text-primary truncate">{'/input-type/{input-value}'}</code>
              </div>
              <p class="text-sm text-text-secondary leading-relaxed pl-10">Determine if input is block, hash, or account</p>
            </li>
            <li class="flex flex-col gap-1">
              <div class="flex items-center gap-2">
                <span class="shrink-0 rounded px-1.5 py-0.5 text-[0.6875rem] font-semibold leading-none bg-accent/15 text-accent">GET</span>
                <code class="text-sm font-mono text-text-primary truncate">/operation-type-counts</code>
              </div>
              <p class="text-sm text-text-secondary leading-relaxed pl-10">Histogram of operation types</p>
            </li>
          </ul>
        </div>

      </div>
    </div>
  </section>

  <!-- API Preview -->
  <ApiPreview />

  <!-- Tech Stack -->
  <section id="tech-stack" class="section-fullscreen py-12 border-t border-border-subtle" aria-labelledby="tech-stack-heading">
    <div class="mx-auto max-w-[75rem] px-6">
      <div class="max-w-2xl" data-animate>
        <h2 id="tech-stack-heading" class="text-3xl sm:text-4xl font-bold tracking-[-0.02em] leading-[1.15]">Built on proven technology</h2>
      </div>

      <div class="mt-10 flex flex-wrap gap-3" data-animate style="--stagger: 1">
        {["PostgreSQL 14", "PostgREST", "HAF", "Docker", "PL/pgSQL", "OpenAPI 3.1"].map((tech) => (
          <span class="rounded-full border border-border-subtle bg-bg-surface px-4 py-2 text-sm text-text-secondary">{tech}</span>
        ))}
      </div>

      <div class="mt-14 grid grid-cols-1 sm:grid-cols-3 gap-4">
        <div class="rounded-2xl border border-border-subtle bg-bg-surface p-7" data-animate style="--stagger: 2">
          <h3 class="text-base font-semibold text-text-primary">SQL-first</h3>
          <p class="mt-2 text-sm text-text-secondary leading-relaxed">Every PostgreSQL function becomes a REST endpoint automatically. Zero server boilerplate.</p>
        </div>
        <div class="rounded-2xl border border-border-subtle bg-bg-surface p-7" data-animate style="--stagger: 3">
          <h3 class="text-base font-semibold text-text-primary">Smart Caching</h3>
          <p class="mt-2 text-sm text-text-secondary leading-relaxed">Historical data cached for 1 year. Live data refreshed every 2 seconds.</p>
        </div>
        <div class="rounded-2xl border border-border-subtle bg-bg-surface p-7" data-animate style="--stagger: 4">
          <h3 class="text-base font-semibold text-text-primary">Fork Resistant</h3>
          <p class="mt-2 text-sm text-text-secondary leading-relaxed">HAF handles blockchain reorganizations. Your data is always consistent.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Architecture Pipeline -->
  <ArchitecturePipeline />

  <!-- CTA -->
  <section class="section-fullscreen py-12 border-t border-border-subtle relative overflow-hidden" aria-labelledby="cta-heading">
    <div class="absolute inset-0 bg-gradient-to-b from-accent/[0.03] to-transparent pointer-events-none"></div>
    <div class="mx-auto max-w-[75rem] px-6 relative">
      <div class="max-w-2xl" data-animate>
        <h2 id="cta-heading" class="text-3xl sm:text-4xl font-bold tracking-[-0.02em] leading-[1.15]">Start Building Today</h2>
        <p class="mt-4 text-text-secondary leading-relaxed">Access the full Hive blockchain through a clean REST API.</p>
      </div>

      <div class="mt-10 grid grid-cols-1 sm:grid-cols-3 gap-4 max-w-3xl">
        <a
          href="https://api.hive.blog/hafbe-api/"
          target="_blank"
          rel="noopener noreferrer"
          class="rounded-2xl border border-border-subtle bg-bg-surface p-7 hover:border-accent/40 transition-colors"
          data-animate style="--stagger: 1"
        >
          <h3 class="text-base font-semibold text-text-primary">API Documentation</h3>
          <p class="mt-2 text-sm text-text-secondary">OpenAPI spec &amp; endpoint reference</p>
        </a>
        <a
          href="https://explore.openhive.network/"
          target="_blank"
          rel="noopener noreferrer"
          class="rounded-2xl border border-border-subtle bg-bg-surface p-7 hover:border-accent/40 transition-colors"
          data-animate style="--stagger: 2"
        >
          <h3 class="text-base font-semibold text-text-primary">Block Explorer</h3>
          <p class="mt-2 text-sm text-text-secondary">Explore Hive blockchain in real-time</p>
        </a>
        <a
          href="https://gitlab.syncad.com/hive/haf_block_explorer"
          target="_blank"
          rel="noopener noreferrer"
          class="rounded-2xl border border-border-subtle bg-bg-surface p-7 hover:border-accent/40 transition-colors"
          data-animate style="--stagger: 3"
        >
          <h3 class="text-base font-semibold text-text-primary">GitLab</h3>
          <p class="mt-2 text-sm text-text-secondary">Source code &amp; issues</p>
        </a>
      </div>
    </div>
  </section>

</Layout>

<script>
  // Block counter
  const counter = document.getElementById("block-counter");
  if (counter) {
    const fmt = new Intl.NumberFormat("en-US");
    const display = (n: number) => { counter.textContent = "#" + fmt.format(n); };
    const fetchBlock = async () => {
      try {
        const res = await fetch("https://api.hive.blog/hafbe-api/last-synced-block");
        if (!res.ok) return;
        const block = Number(await res.text());
        if (block > 0) display(block);
      } catch {}
    };
    fetchBlock();
    setInterval(fetchBlock, 3000);
  }

  // Scroll animations
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((e) => { if (e.isIntersecting) { e.target.classList.add("visible"); observer.unobserve(e.target); } });
    },
    { threshold: 0.15 }
  );
  document.querySelectorAll("[data-animate]").forEach((el) => observer.observe(el));
</script>
